@echo off
chcp 65001 >nul 2>&1
setlocal EnableDelayedExpansion

:: =============================================================================
::                    ПИТОМЕЦ+ - ПОЛНЫЙ ЗАПУСК ПРОЕКТА
:: =============================================================================
:: Этот скрипт запускает ОБА сервера одновременно (бекенд и фронтенд)
:: БЕЗ запроса подтверждения для быстрого старта разработки
:: =============================================================================

echo.
echo ╔══════════════════════════════════════════════════════════════════════════╗
echo ║              ПИТОМЕЦ+ - ПОЛНЫЙ ЗАПУСК ПРОЕКТА                            ║
echo ╠══════════════════════════════════════════════════════════════════════════╣
echo ║                                                                          ║
echo ║  Этот скрипт автоматически запускает:                                    ║
echo ║                                                                          ║
echo ║    ► БЕКЕНД  (Django)  на порту 8077                                     ║
echo ║    ► ФРОНТЕНД (React)  на порту 5199                                     ║
echo ║                                                                          ║
echo ║  Порты выбраны уникальными для избежания конфликтов в локальной сети     ║
echo ║                                                                          ║
echo ╚══════════════════════════════════════════════════════════════════════════╝
echo.

:: -----------------------------------------------------------------------------
:: ОБЪЯСНЕНИЕ: ПОЧЕМУ НУЖНЫ ДВА СЕРВЕРА?
:: -----------------------------------------------------------------------------
echo ┌──────────────────────────────────────────────────────────────────────────┐
echo │  АРХИТЕКТУРА ПРОЕКТА:                                                    │
echo │                                                                          │
echo │  ┌─────────────────┐          ┌─────────────────┐                        │
echo │  │    ФРОНТЕНД     │  ─────►  │     БЕКЕНД      │                        │
echo │  │  (React/Vite)   │  HTTP    │    (Django)     │                        │
echo │  │   Порт: 5199    │  API     │   Порт: 8077    │                        │
echo │  └─────────────────┘          └─────────────────┘                        │
echo │        ▲                              ▲                                  │
echo │        │                              │                                  │
echo │    Браузер                      База данных                              │
echo │   пользователя                  (PostgreSQL)                             │
echo │                                                                          │
echo │  Фронтенд отображает интерфейс, а бекенд обрабатывает логику и данные.   │
echo │                                                                          │
echo └──────────────────────────────────────────────────────────────────────────┘
echo.

:: -----------------------------------------------------------------------------
:: ОБЪЯСНЕНИЕ: ЧТО ТАКОЕ CORS И ЗАЧЕМ ОН НУЖЕН?
:: -----------------------------------------------------------------------------
echo ┌──────────────────────────────────────────────────────────────────────────┐
echo │  ПОЧЕМУ ВАЖНЫ ПОРТЫ И CORS:                                              │
echo │                                                                          │
echo │  CORS (Cross-Origin Resource Sharing) - это механизм безопасности        │
echo │  браузера, который блокирует запросы между разными "источниками".        │
echo │                                                                          │
echo │  "Источник" = протокол + домен + порт                                    │
echo │                                                                          │
echo │  Примеры РАЗНЫХ источников:                                              │
echo │    • http://localhost:5199 (фронтенд)                                    │
echo │    • http://localhost:8077 (бекенд)                                      │
echo │                                                                          │
echo │  Без настройки CORS браузер заблокирует запросы с фронтенда на бекенд!   │
echo │                                                                          │
echo │  Мы настроили CORS в backend/config/settings.py, чтобы разрешить         │
echo │  запросы с портов фронтенда (5199, 5174 и др.)                           │
echo │                                                                          │
echo └──────────────────────────────────────────────────────────────────────────┘
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 1: Проверка наличия необходимых файлов
:: -----------------------------------------------------------------------------
echo [ШАГ 1/4] Проверка структуры проекта...

if not exist "%~dp0backend\manage.py" (
    echo [ОШИБКА] Не найден файл backend/manage.py!
    echo          Убедитесь, что вы запускаете скрипт из корня проекта.
    pause
    exit /b 1
)
echo            ► backend/manage.py - найден

if not exist "%~dp0frontend\package.json" (
    echo [ОШИБКА] Не найден файл frontend/package.json!
    echo          Убедитесь, что фронтенд-часть проекта установлена.
    pause
    exit /b 1
)
echo            ► frontend/package.json - найден

if not exist "%~dp0backend\venv\Scripts\python.exe" (
    echo [ПРЕДУПРЕЖДЕНИЕ] Виртуальное окружение Python не найдено!
    echo                  Бекенд может не запуститься корректно.
    echo                  Создайте его: cd backend ^& python -m venv venv
)
echo            [OK] Структура проекта в порядке
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 2: Создание временных файлов для отдельного запуска без подтверждения
:: -----------------------------------------------------------------------------
echo [ШАГ 2/4] Подготовка серверов к запуску...

:: Создаем временный скрипт для бекенда (без подтверждения)
echo @echo off > "%TEMP%\pitomets_backend_auto.bat"
echo chcp 65001 ^>nul 2^>^&1 >> "%TEMP%\pitomets_backend_auto.bat"
echo title ПИТОМЕЦ+ - Бекенд (порт 8077) >> "%TEMP%\pitomets_backend_auto.bat"
echo cd /d "%~dp0backend" >> "%TEMP%\pitomets_backend_auto.bat"
echo call venv\Scripts\activate.bat >> "%TEMP%\pitomets_backend_auto.bat"
echo echo. >> "%TEMP%\pitomets_backend_auto.bat"
echo echo ══════════════════════════════════════════════════════════════════ >> "%TEMP%\pitomets_backend_auto.bat"
echo echo   БЕКЕНД ПИТОМЕЦ+ запущен на http://localhost:8077 >> "%TEMP%\pitomets_backend_auto.bat"
echo echo   API: http://localhost:8077/api/ >> "%TEMP%\pitomets_backend_auto.bat"
echo echo   Админка: http://localhost:8077/admin/ >> "%TEMP%\pitomets_backend_auto.bat"
echo echo ══════════════════════════════════════════════════════════════════ >> "%TEMP%\pitomets_backend_auto.bat"
echo echo. >> "%TEMP%\pitomets_backend_auto.bat"
echo python manage.py runserver 0.0.0.0:8077 >> "%TEMP%\pitomets_backend_auto.bat"
echo pause >> "%TEMP%\pitomets_backend_auto.bat"

:: Создаем временный скрипт для фронтенда (без подтверждения)
echo @echo off > "%TEMP%\pitomets_frontend_auto.bat"
echo chcp 65001 ^>nul 2^>^&1 >> "%TEMP%\pitomets_frontend_auto.bat"
echo title ПИТОМЕЦ+ - Фронтенд (порт 5199) >> "%TEMP%\pitomets_frontend_auto.bat"
echo cd /d "%~dp0frontend" >> "%TEMP%\pitomets_frontend_auto.bat"
echo set VITE_API_URL=http://localhost:8077/api >> "%TEMP%\pitomets_frontend_auto.bat"
echo echo. >> "%TEMP%\pitomets_frontend_auto.bat"
echo echo ══════════════════════════════════════════════════════════════════ >> "%TEMP%\pitomets_frontend_auto.bat"
echo echo   ФРОНТЕНД ПИТОМЕЦ+ запущен на http://localhost:5199 >> "%TEMP%\pitomets_frontend_auto.bat"
echo echo   Бекенд API: http://localhost:8077/api/ >> "%TEMP%\pitomets_frontend_auto.bat"
echo echo ══════════════════════════════════════════════════════════════════ >> "%TEMP%\pitomets_frontend_auto.bat"
echo echo. >> "%TEMP%\pitomets_frontend_auto.bat"
echo call npm run dev -- --port 5199 --host >> "%TEMP%\pitomets_frontend_auto.bat"
echo pause >> "%TEMP%\pitomets_frontend_auto.bat"

echo            [OK] Скрипты подготовлены
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 3: Запуск бекенда в новом окне
:: -----------------------------------------------------------------------------
echo [ШАГ 3/4] Запуск бекенда...
echo            Бекенд стартует на http://localhost:8077
start "ПИТОМЕЦ+ - Бекенд (порт 8077)" cmd /c "%TEMP%\pitomets_backend_auto.bat"
echo            [OK] Окно бекенда открыто
echo.

:: -----------------------------------------------------------------------------
:: Ожидание инициализации бекенда
:: -----------------------------------------------------------------------------
echo            Ожидание инициализации бекенда (5 секунд)...
echo            Это необходимо, чтобы API был готов к запросам
timeout /t 5 /nobreak >nul
echo            [OK] Пауза завершена
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 4: Запуск фронтенда в новом окне
:: -----------------------------------------------------------------------------
echo [ШАГ 4/4] Запуск фронтенда...
echo            Фронтенд стартует на http://localhost:5199
start "ПИТОМЕЦ+ - Фронтенд (порт 5199)" cmd /c "%TEMP%\pitomets_frontend_auto.bat"
echo            [OK] Окно фронтенда открыто
echo.

:: -----------------------------------------------------------------------------
:: ИТОГОВАЯ ИНФОРМАЦИЯ
:: -----------------------------------------------------------------------------
echo.
echo ╔══════════════════════════════════════════════════════════════════════════╗
echo ║                    СЕРВЕРЫ УСПЕШНО ЗАПУЩЕНЫ!                             ║
echo ╠══════════════════════════════════════════════════════════════════════════╣
echo ║                                                                          ║
echo ║  АДРЕСА СЕРВЕРОВ:                                                        ║
echo ║                                                                          ║
echo ║    ► ФРОНТЕНД:     http://localhost:5199                                 ║
echo ║    ► БЕКЕНД API:   http://localhost:8077/api/                            ║
echo ║    ► АДМИНКА:      http://localhost:8077/admin/                          ║
echo ║                                                                          ║
echo ╠══════════════════════════════════════════════════════════════════════════╣
echo ║                                                                          ║
echo ║  УПРАВЛЕНИЕ:                                                             ║
echo ║                                                                          ║
echo ║    ► Для остановки закройте оба открытых окна терминала                  ║
echo ║    ► Или нажмите Ctrl+C в каждом окне                                    ║
echo ║                                                                          ║
echo ╠══════════════════════════════════════════════════════════════════════════╣
echo ║                                                                          ║
echo ║  УЧЕТНЫЕ ДАННЫЕ АДМИНКИ:                                                 ║
echo ║                                                                          ║
echo ║    ► Логин:    admin                                                     ║
echo ║    ► Пароль:   admin123                                                  ║
echo ║                                                                          ║
echo ╚══════════════════════════════════════════════════════════════════════════╝
echo.
echo  Это окно можно закрыть. Серверы работают в отдельных окнах.
echo.
pause



