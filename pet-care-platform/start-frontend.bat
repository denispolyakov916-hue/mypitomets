@echo off
chcp 65001 >nul 2>&1
setlocal EnableDelayedExpansion

:: =============================================================================
::                    ПИТОМЕЦ+ - ЗАПУСК ФРОНТЕНДА (Vite + React)
:: =============================================================================
:: Этот скрипт запускает Vite dev-сервер на уникальном порту 5199
:: Порт выбран специально, чтобы избежать конфликтов с другими сервисами
:: =============================================================================

echo.
echo ╔══════════════════════════════════════════════════════════════════════════╗
echo ║                    ПИТОМЕЦ+ - ЗАПУСК ФРОНТЕНДА                           ║
echo ╠══════════════════════════════════════════════════════════════════════════╣
echo ║  Порт фронтенда: 5199 (уникальный порт для избежания конфликтов)         ║
echo ╚══════════════════════════════════════════════════════════════════════════╝
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 1: Переход в директорию фронтенда
:: -----------------------------------------------------------------------------
echo [ШАГ 1/4] Переход в директорию фронтенда...
cd /d "%~dp0frontend"
if errorlevel 1 (
    echo [ОШИБКА] Не удалось перейти в директорию frontend!
    pause
    exit /b 1
)
echo            Рабочая директория: %CD%
echo            [OK] Директория найдена
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 2: Проверка наличия Node.js
:: -----------------------------------------------------------------------------
echo [ШАГ 2/4] Проверка Node.js...
echo            Node.js необходим для сборки и запуска React-приложения
node --version >nul 2>&1
if errorlevel 1 (
    echo.
    echo [ОШИБКА] Node.js не установлен!
    echo          Скачайте Node.js 18+ с https://nodejs.org/
    pause
    exit /b 1
)
for /f "tokens=*" %%i in ('node --version 2^>^&1') do set NODE_VERSION=%%i
echo            Версия: %NODE_VERSION%
echo            [OK] Node.js найден
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 3: Проверка npm (пакетный менеджер)
:: -----------------------------------------------------------------------------
echo [ШАГ 3/4] Проверка npm...
echo            npm используется для управления JavaScript-пакетами
call npm --version >nul 2>&1
if errorlevel 1 (
    echo [ОШИБКА] npm не доступен!
    pause
    exit /b 1
)
for /f "tokens=*" %%i in ('npm --version 2^>^&1') do set NPM_VERSION=%%i
echo            Версия: %NPM_VERSION%
echo            [OK] npm найден
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 4: Установка зависимостей (если необходимо)
:: -----------------------------------------------------------------------------
echo [ШАГ 4/4] Проверка зависимостей проекта...
if not exist "node_modules" (
    echo            Папка node_modules не найдена, устанавливаю зависимости...
    echo            Это может занять несколько минут при первом запуске...
    call npm install
    if errorlevel 1 (
        echo [ОШИБКА] Не удалось установить зависимости!
        pause
        exit /b 1
    )
    echo            [OK] Зависимости успешно установлены
) else (
    echo            [OK] Зависимости уже установлены
)
echo.

:: -----------------------------------------------------------------------------
:: ЧТЕНИЕ ПОРТА БЕКЕНДА ИЗ КОНФИГУРАЦИИ
:: -----------------------------------------------------------------------------
:: Порт бекенда берется из vite.config.js (по умолчанию 8077)
:: Используем IPv4 адрес для работы в локальной сети
set BACKEND_PORT=8077
set BACKEND_HOST=http://192.168.1.11:%BACKEND_PORT%

:: -----------------------------------------------------------------------------
:: ИНФОРМАЦИЯ О СЕРВЕРЕ
:: -----------------------------------------------------------------------------
echo ╔══════════════════════════════════════════════════════════════════════════╗
echo ║                       ИНФОРМАЦИЯ О СЕРВЕРЕ                               ║
echo ╠══════════════════════════════════════════════════════════════════════════╣
echo ║                                                                          ║
echo ║  ФРОНТЕНД будет запущен на:                                              ║
echo ║                                                                          ║
echo ║    ► Локальный доступ:    http://localhost:5199                          ║
echo ║    ► Сетевой доступ:      http://ваш-ip:5199                             ║
echo ║                                                                          ║
echo ╠══════════════════════════════════════════════════════════════════════════╣
echo ║                                                                          ║
echo ║  ВАЖНО! Бекенд должен быть запущен на:                                   ║
echo ║                                                                          ║
echo ║    ► %BACKEND_HOST%                                          ║
echo ║    ► API:    %BACKEND_HOST%/api/                             ║
echo ║    ► Админка: %BACKEND_HOST%/admin/                          ║
echo ║                                                                          ║
echo ║  Если бекенд не запущен, API-запросы не будут работать!                  ║
echo ║  (используйте start-backend.bat для запуска бекенда)                     ║
echo ║                                                                          ║
echo ╚══════════════════════════════════════════════════════════════════════════╝
echo.

:: -----------------------------------------------------------------------------
:: ОБЪЯСНЕНИЕ СВЯЗИ ФРОНТЕНД-БЕКЕНД
:: -----------------------------------------------------------------------------
echo ┌──────────────────────────────────────────────────────────────────────────┐
echo │  КАК ЭТО РАБОТАЕТ:                                                       │
echo │                                                                          │
echo │  1. Фронтенд (React) отправляет запросы на /api/*                        │
echo │  2. Vite-прокси перенаправляет их на бекенд (порт 8077)                  │
echo │  3. Бекенд (Django) обрабатывает запросы и возвращает данные             │
echo │  4. Это настроено в файле: frontend/vite.config.js                       │
echo │                                                                          │
echo └──────────────────────────────────────────────────────────────────────────┘
echo.

:: -----------------------------------------------------------------------------
:: ЗАПРОС ПОДТВЕРЖДЕНИЯ ЗАПУСКА
:: -----------------------------------------------------------------------------
echo ════════════════════════════════════════════════════════════════════════════
set /p confirm="  Подтвердите запуск фронтенда (y/n): "
if /i not "%confirm%"=="y" (
    echo.
    echo  Запуск отменен пользователем.
    pause
    exit /b 0
)
echo ════════════════════════════════════════════════════════════════════════════
echo.

:: -----------------------------------------------------------------------------
:: ЗАПУСК VITE DEV-СЕРВЕРА
:: -----------------------------------------------------------------------------
echo [ЗАПУСК] Стартую Vite dev-сервер на порту 5199...
echo          Нажмите Ctrl+C для остановки сервера
echo.
echo ────────────────────────────────────────────────────────────────────────────

:: НЕ устанавливаем VITE_API_URL - используем Vite прокси из vite.config.js
:: Это позволяет избежать CORS проблем и работает как через localhost, так и через сеть
call npm run dev -- --port 5199 --host

echo ────────────────────────────────────────────────────────────────────────────
echo.
echo [СТОП] Сервер остановлен.
pause



