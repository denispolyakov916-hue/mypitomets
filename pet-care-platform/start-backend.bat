@echo off
chcp 65001 >nul 2>&1
setlocal EnableDelayedExpansion

:: =============================================================================
::                    ПИТОМЕЦ+ - ЗАПУСК БЕКЕНДА (Django)
:: =============================================================================
:: Этот скрипт запускает Django-сервер на уникальном порту 8077
:: Порт выбран специально, чтобы избежать конфликтов с другими сервисами
:: =============================================================================

echo.
echo ╔══════════════════════════════════════════════════════════════════════════╗
echo ║                    ПИТОМЕЦ+ - ЗАПУСК БЕКЕНДА                             ║
echo ╠══════════════════════════════════════════════════════════════════════════╣
echo ║  Порт бекенда: 8077 (уникальный порт для избежания конфликтов)           ║
echo ╚══════════════════════════════════════════════════════════════════════════╝
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 1: Переход в директорию бекенда
:: -----------------------------------------------------------------------------
echo [ШАГ 1/6] Переход в директорию бекенда...
cd /d "%~dp0backend"
if errorlevel 1 (
    echo [ОШИБКА] Не удалось перейти в директорию backend!
    pause
    exit /b 1
)
echo            Рабочая директория: %CD%
echo            [OK] Директория найдена
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 2: Проверка наличия Python в системе
:: -----------------------------------------------------------------------------
echo [ШАГ 2/6] Проверка Python...
echo            Python необходим для запуска Django-сервера
python --version >nul 2>&1
if errorlevel 1 (
    echo.
    echo [ОШИБКА] Python не установлен или не добавлен в PATH!
    echo          Скачайте Python 3.10+ с https://www.python.org/
    echo          При установке обязательно отметьте "Add Python to PATH"
    pause
    exit /b 1
)
for /f "tokens=*" %%i in ('python --version 2^>^&1') do set PYTHON_VERSION=%%i
echo            Версия: %PYTHON_VERSION%
echo            [OK] Python найден
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 3: Проверка виртуального окружения
:: -----------------------------------------------------------------------------
echo [ШАГ 3/6] Проверка виртуального окружения...
echo            Виртуальное окружение изолирует зависимости проекта
if not exist "venv\Scripts\python.exe" (
    echo.
    echo [ОШИБКА] Виртуальное окружение не найдено!
    echo          Создайте его командой: python -m venv venv
    echo          Затем установите зависимости: pip install -r requirements.txt
    pause
    exit /b 1
)
echo            Путь: %CD%\venv
echo            [OK] Виртуальное окружение найдено
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 4: Активация виртуального окружения
:: -----------------------------------------------------------------------------
echo [ШАГ 4/6] Активация виртуального окружения...
echo            Это подключает все установленные Python-пакеты проекта
call venv\Scripts\activate.bat
if errorlevel 1 (
    echo [ОШИБКА] Не удалось активировать виртуальное окружение!
    pause
    exit /b 1
)
echo            [OK] Виртуальное окружение активировано
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 5: Проверка и применение миграций базы данных
:: -----------------------------------------------------------------------------
echo [ШАГ 5/6] Проверка базы данных и миграций...
echo            Миграции синхронизируют структуру БД с моделями Django
python manage.py migrate --check >nul 2>&1
if errorlevel 1 (
    echo            Обнаружены непримененные миграции, применяю...
    python manage.py migrate --noinput
    if errorlevel 1 (
        echo [ПРЕДУПРЕЖДЕНИЕ] Ошибка миграций, но продолжаем...
    ) else (
        echo            [OK] Миграции успешно применены
    )
) else (
    echo            [OK] База данных в актуальном состоянии
)
echo.

:: -----------------------------------------------------------------------------
:: ШАГ 6: Загрузка тестовых данных
:: -----------------------------------------------------------------------------
echo [ШАГ 6/6] Загрузка тестовых данных...
echo            Это заполняет базу начальными данными для работы
python manage.py load_test_data --noinput >nul 2>&1
python manage.py load_courses --noinput >nul 2>&1
echo            [OK] Тестовые данные загружены
echo.

:: -----------------------------------------------------------------------------
:: ИНФОРМАЦИЯ О СЕРВЕРЕ
:: -----------------------------------------------------------------------------
echo ╔══════════════════════════════════════════════════════════════════════════╗
echo ║                       ИНФОРМАЦИЯ О СЕРВЕРЕ                               ║
echo ╠══════════════════════════════════════════════════════════════════════════╣
echo ║                                                                          ║
echo ║  БЕКЕНД будет запущен на:                                                ║
echo ║                                                                          ║
echo ║    ► Локальный доступ:    http://localhost:8077                          ║
echo ║    ► Сетевой доступ:      http://192.168.1.11:8077                       ║
echo ║                                                                          ║
echo ║  Доступные эндпоинты:                                                    ║
echo ║    ► API:                 http://192.168.1.11:8077/api/                  ║
echo ║    ► Админка Django:      http://192.168.1.11:8077/admin/                ║
echo ║                                                                          ║
echo ╠══════════════════════════════════════════════════════════════════════════╣
echo ║  ФРОНТЕНД должен быть запущен на: http://localhost:5199                  ║
echo ║  (используйте start-frontend.bat для запуска фронтенда)                  ║
echo ╚══════════════════════════════════════════════════════════════════════════╝
echo.

:: -----------------------------------------------------------------------------
:: ЗАПРОС ПОДТВЕРЖДЕНИЯ ЗАПУСКА
:: -----------------------------------------------------------------------------
echo ════════════════════════════════════════════════════════════════════════════
set /p confirm="  Подтвердите запуск бекенда (y/n): "
if /i not "%confirm%"=="y" (
    echo.
    echo  Запуск отменен пользователем.
    pause
    exit /b 0
)
echo ════════════════════════════════════════════════════════════════════════════
echo.

:: -----------------------------------------------------------------------------
:: ЗАПУСК DJANGO-СЕРВЕРА
:: -----------------------------------------------------------------------------
echo [ЗАПУСК] Стартую Django-сервер на порту 8077...
echo          Нажмите Ctrl+C для остановки сервера
echo.
echo ────────────────────────────────────────────────────────────────────────────

python manage.py runserver 0.0.0.0:8077

echo ────────────────────────────────────────────────────────────────────────────
echo.
echo [СТОП] Сервер остановлен.
pause



