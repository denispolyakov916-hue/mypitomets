# =============================================================================
# PRODUCTION — переменные окружения backend
# Скопируйте в backend/.env и заполните реальными значениями.
# Реальные секреты НЕ коммитим — в git хранится только этот пример с плейсхолдерами.
# =============================================================================

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
# Сгенерировать: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# URL фронтенда (для CORS, ссылок в email)
CLIENT_URL=https://yourdomain.com
# URL бэкенда (для формирования ссылок активации)
API_URL=https://yourdomain.com

# SSL редирект (включить после настройки HTTPS)
SECURE_SSL_REDIRECT=True

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
DB_NAME=pitomets_db
DB_USER=pitomets
DB_PASSWORD=your-db-password
DB_HOST=db
DB_PORT=5432

# ---------------------------------------------------------------------------
# Email (SMTP)
# ---------------------------------------------------------------------------
# Для продакшена рекомендуется: SendGrid, Amazon SES, Mailgun
SMTP_HOST=smtp.example.com
SMTP_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ---------------------------------------------------------------------------
# Yandex Cloud S3 (Object Storage)
# ---------------------------------------------------------------------------
YANDEX_S3_ACCESS_KEY_ID=your-s3-access-key
YANDEX_S3_SECRET_ACCESS_KEY=your-s3-secret-key
YANDEX_S3_BUCKET_PUBLIC=your-public-bucket
YANDEX_S3_BUCKET_PRIVATE=your-private-bucket
YANDEX_S3_ENDPOINT_URL=https://storage.yandexcloud.net
YANDEX_S3_REGION=ru-central1

# ---------------------------------------------------------------------------
# Redis (раскомментировать при использовании)
# ---------------------------------------------------------------------------
# REDIS_URL=redis://redis:6379/1

# ---------------------------------------------------------------------------
# CDN (раскомментировать при подключении)
# ---------------------------------------------------------------------------
# USE_CDN=true
# CDN_DOMAIN=cdn.yourdomain.com
