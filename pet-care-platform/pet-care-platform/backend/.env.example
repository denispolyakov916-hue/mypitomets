# =============================================================================
# Пример переменных окружения backend (DEV)
# Скопируйте этот файл в backend/.env и подставьте реальные значения.
# Реальные секреты НЕ коммитим — в git хранится только этот пример с плейсхолдерами.
# =============================================================================

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
# Секретный ключ Django. Сгенерировать можно так:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key

# Режим отладки (True для разработки, False для продакшена)
DEBUG=True

# Разрешённые хосты (через запятую)
ALLOWED_HOSTS=localhost,127.0.0.1

# URL фронтенда (для CORS и ссылок в письмах)
CLIENT_URL=http://localhost:5199

# URL бэкенда (для формирования ссылок активации)
API_URL=http://localhost:8077

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DB_NAME=pitomets_db
DB_USER=pitomets
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@example.com

# -----------------------------------------------------------------------------
# Yandex Cloud S3 (Object Storage)
# -----------------------------------------------------------------------------
YANDEX_S3_ACCESS_KEY_ID=your-s3-access-key
YANDEX_S3_SECRET_ACCESS_KEY=your-s3-secret-key
YANDEX_S3_BUCKET_PUBLIC=your-public-bucket
YANDEX_S3_BUCKET_PRIVATE=your-private-bucket
YANDEX_S3_ENDPOINT_URL=https://storage.yandexcloud.net
YANDEX_S3_REGION=ru-central1

# -----------------------------------------------------------------------------
# ИИ-ассистент «Пуф» (LLM)
# -----------------------------------------------------------------------------
# Бэкенд модели: stub (заглушка, по умолчанию) | claude | yandex | gigachat.
# Со 'stub' ассистент работает без ключей и без сети — этого достаточно для
# разработки. Для реальной модели выберите провайдера и заполните его ключи.
ASSISTANT_LLM_BACKEND=stub
# Лимит запросов к ассистенту на пользователя (DRF throttle), напр. 20/min, 100/hour.
ASSISTANT_RATE_LIMIT=20/min

# Claude (Anthropic). Прямой доступ к api.anthropic.com из РФ может требовать прокси.
ASSISTANT_ANTHROPIC_API_KEY=your-anthropic-key
ASSISTANT_CLAUDE_MODEL=claude-3-5-sonnet-latest
ASSISTANT_HTTP_PROXY=

# YandexGPT (RU-native, прокси не нужен).
ASSISTANT_YANDEX_API_KEY=your-yandex-api-key
ASSISTANT_YANDEX_FOLDER_ID=
ASSISTANT_YANDEX_MODEL=yandexgpt/latest

# GigaChat (Сбер, RU-native). AUTH_KEY — это Base64(client_id:client_secret).
ASSISTANT_GIGACHAT_AUTH_KEY=
ASSISTANT_GIGACHAT_SCOPE=GIGACHAT_API_PERS
ASSISTANT_GIGACHAT_MODEL=GigaChat
# Путь к корневому сертификату Минцифры (рекомендуется). Либо VERIFY=false на стенде.
ASSISTANT_GIGACHAT_CA_BUNDLE=
ASSISTANT_GIGACHAT_VERIFY=true

# -----------------------------------------------------------------------------
# Dinozavrik integration
# -----------------------------------------------------------------------------
# Dinozavrik -> Питомец+ (они вызывают наши /api/integrations/distributor/v1/*)
DINOZAVRIK_SUPPLIER_CODE=dinozavrik
DINOZAVRIK_DISTRIBUTOR_API_KEY=your-distributor-api-key
DINOZAVRIK_DISTRIBUTOR_SECRET=replace_me
# Альтернатива для нескольких ключей:
# DISTRIBUTOR_INTEGRATION_KEYS_JSON=[{"api_key":"dk_live_replace_me","secret":"replace_me","supplier_code":"dinozavrik"}]

# Питомец+ -> Dinozavrik (мы отправляем им оплаченные заказы)
DINOZAVRIK_ORDER_SYNC_ENABLED=False
DINOZAVRIK_API_BASE_URL=https://api.dinozavrik.ru/pitomets-integration/v1
DINOZAVRIK_PITOMETS_API_KEY=your-pitomets-api-key
DINOZAVRIK_PITOMETS_SECRET=replace_me
DINOZAVRIK_API_TIMEOUT_SECONDS=10
DINOZAVRIK_PAYMENT_COLLECTOR=pitometsplus
DINOZAVRIK_SETTLEMENT_MODEL=weekly_payout
