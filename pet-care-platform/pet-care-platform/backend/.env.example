# =============================================================================
# Пример переменных окружения backend (DEV)
# Скопируйте этот файл в backend/.env и подставьте реальные значения.
# Реальные секреты НЕ коммитим — в git хранится только этот пример с плейсхолдерами.
# =============================================================================

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
# Секретный ключ Django. Сгенерировать можно так:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key

# Режим отладки (True для разработки, False для продакшена)
DEBUG=True

# Разрешённые хосты (через запятую)
ALLOWED_HOSTS=localhost,127.0.0.1

# URL фронтенда (для CORS и ссылок в письмах)
CLIENT_URL=http://localhost:5199

# URL бэкенда (для формирования ссылок активации)
API_URL=http://localhost:8077

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DB_NAME=pitomets_db
DB_USER=pitomets
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@example.com

# -----------------------------------------------------------------------------
# Yandex Cloud S3 (Object Storage)
# -----------------------------------------------------------------------------
YANDEX_S3_ACCESS_KEY_ID=your-s3-access-key
YANDEX_S3_SECRET_ACCESS_KEY=your-s3-secret-key
YANDEX_S3_BUCKET_PUBLIC=your-public-bucket
YANDEX_S3_BUCKET_PRIVATE=your-private-bucket
YANDEX_S3_ENDPOINT_URL=https://storage.yandexcloud.net
YANDEX_S3_REGION=ru-central1
