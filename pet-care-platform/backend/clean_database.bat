@echo off
echo ====================================================
echo         ОЧИСТКА БАЗЫ ДАННЫХ ПИТОМЕЦ+
echo ====================================================
echo.
echo ВНИМАНИЕ: Этот скрипт удалит ВСЕ пользовательские данные!
echo Убедитесь, что у вас есть backup базы данных!
echo.
pause

echo.
echo Выполнение очистки базы данных...
echo.

psql -U pitomets -d pitomets_db -f clean_database.sql

if %errorlevel% equ 0 (
    echo.
    echo ====================================================
    echo ✅ БАЗА ДАННЫХ УСПЕШНО ОЧИЩЕНА!
    echo ====================================================
    echo.
    echo Теперь вы можете:
    echo 1. Запустить python manage.py createsuperuser
    echo 2. Добавить тестовые данные через админку
    echo 3. Начать отладку с чистого листа
    echo.
) else (
    echo.
    echo ====================================================
    echo ❌ ОШИБКА ПРИ ОЧИСТКЕ БАЗЫ ДАННЫХ
    echo ====================================================
    echo.
    echo Проверьте:
    echo 1. Запущен ли PostgreSQL
    echo 2. Правильны ли параметры подключения
    echo 3. Есть ли права на выполнение операций
    echo.
)

echo Нажмите любую клавишу для выхода...
pause >nul