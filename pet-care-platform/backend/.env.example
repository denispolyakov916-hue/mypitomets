# =============================================================================
# РќРђРЎРўР РћР™РљР DJANGO
# =============================================================================

# РЎРµРєСЂРµС‚РЅС‹Р№ РєР»СЋС‡ Django (РћР‘РЇР—РђРўР•Р›Р¬РќРћ РёР·РјРµРЅРёС‚Рµ РІ РїСЂРѕРґР°РєС€РµРЅРµ!)
DJANGO_SECRET_KEY=django-insecure-change-in-production

# Р РµР¶РёРј РѕС‚Р»Р°РґРєРё (True РґР»СЏ СЂР°Р·СЂР°Р±РѕС‚РєРё, False РґР»СЏ РїСЂРѕРґР°РєС€РµРЅР°)
DEBUG=True

# Р Р°Р·СЂРµС€РµРЅРЅС‹Рµ С…РѕСЃС‚С‹ (С‡РµСЂРµР· Р·Р°РїСЏС‚СѓСЋ)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# URL РєР»РёРµРЅС‚СЃРєРѕРіРѕ РїСЂРёР»РѕР¶РµРЅРёСЏ (С„СЂРѕРЅС‚РµРЅРґ)
CLIENT_URL=http://localhost:5173

# URL API СЃРµСЂРІРµСЂР°
API_URL=http://192.168.1.11:8000

# =============================================================================
# РќРђРЎРўР РћР™РљР Р‘РђР—Р« Р”РђРќРќР«РҐ PostgreSQL
# =============================================================================

# РРјСЏ Р±Р°Р·С‹ РґР°РЅРЅС‹С…
DB_NAME=pitomets_db

# РџРѕР»СЊР·РѕРІР°С‚РµР»СЊ Р±Р°Р·С‹ РґР°РЅРЅС‹С…
DB_USER=pitomets

# РџР°СЂРѕР»СЊ РїРѕР»СЊР·РѕРІР°С‚РµР»СЏ Р±Р°Р·С‹ РґР°РЅРЅС‹С…
DB_PASSWORD=pitomets_password

# РҐРѕСЃС‚ Р±Р°Р·С‹ РґР°РЅРЅС‹С…
DB_HOST=localhost

# РџРѕСЂС‚ Р±Р°Р·С‹ РґР°РЅРЅС‹С…
DB_PORT=5432

# =============================================================================
# РќРђРЎРўР РћР™РљР EMAIL (SMTP)
# =============================================================================

# SMTP СЃРµСЂРІРµСЂ (РЅР°РїСЂРёРјРµСЂ, smtp.gmail.com)
SMTP_HOST=smtp.gmail.com

# SMTP РїРѕСЂС‚ (587 РґР»СЏ TLS, 465 РґР»СЏ SSL)
SMTP_PORT=587

# РСЃРїРѕР»СЊР·РѕРІР°С‚СЊ TLS (true/false)
EMAIL_USE_TLS=true

# РСЃРїРѕР»СЊР·РѕРІР°С‚СЊ SSL (true/false)
EMAIL_USE_SSL=false

# Email РґР»СЏ РѕС‚РїСЂР°РІРєРё РїРёСЃРµРј
SMTP_USER=your-email@gmail.com

# РџР°СЂРѕР»СЊ РѕС‚ email (РґР»СЏ Gmail РёСЃРїРѕР»СЊР·СѓР№С‚Рµ РїР°СЂРѕР»СЊ РїСЂРёР»РѕР¶РµРЅРёСЏ)
SMTP_PASSWORD=your-app-password

# Email РѕС‚РїСЂР°РІРёС‚РµР»СЏ РїРѕ СѓРјРѕР»С‡Р°РЅРёСЋ
DEFAULT_FROM_EMAIL=noreply@petcare-platform.com
