{
  "_meta": {
    "version": "1.0",
    "created": "2026-01-18",
    "description": "Коэффициенты для расчёта суточной калорийности питания собак и кошек",
    "sources": ["FEDIAF 2021", "NRC 2006", "AAHA 2021", "AAFCO 2024"]
  },

  "formulas": {
    "dog": {
      "rer": "70 × (weight_kg)^0.75",
      "mer": "RER × K_age × K_neutering × K_activity × K_size × K_coat × K_climate × K_housing"
    },
    "cat": {
      "rer": "70 × (weight_kg)^0.67",
      "mer": "RER × K_age × K_neutering × K_activity × K_coat × K_climate"
    }
  },

  "size_category": {
